# Copy to `.env` (in revamp/backend/) and fill in your key.

# Which provider powers extraction and the chat copilot: "openai" | "fallback".
# "fallback" is a deterministic offline proposer that needs no key.
LLM_PROVIDER=openai

# Your OpenAI API key (required when LLM_PROVIDER=openai).
OPENAI_API_KEY=sk-your-key-here

# Model used for structured extraction / chat. Must support structured outputs.
OPENAI_MODEL=gpt-4o-2024-08-06

# SQLite by default. In Render, set this to the Neon pooled connection string.
# Keep the production connection string in the Render dashboard, not this file.
DATABASE_URL=sqlite:///./fragilitygraph.db

# The browser origin allowed to call this API. In Render, set this to the final
# Vercel origin without a trailing slash.
FRONTEND_ORIGIN=http://localhost:3000
